---
import Layout from "../components/Layout.astro";
import { Header as HeaderBlock, Footer as FooterBlock, VideoHero as VideoHeroBlock, NavMenu } from "astro-blocks";

const links = [
  { label: "Home", href: "/" },
  { label: "Header", href: "/header" },
  { label: "Footer", href: "/footer" },
  { label: "Video Hero", href: "/video-hero" },
  { label: "Image Hero", href: "/image-hero" },
];
---

<Layout>
  <HeaderBlock>
    <a class="logo" href="/">spacez</a>
    <NavMenu links={links} />
  </HeaderBlock>

  <VideoHeroBlock
    title="EXPANDING HUMANITY BEYOND EARTH"
    subtitle="Humanity's future does not end on Earth. Our mission is to develop the technology that will enable people to explore, live, and work beyond our planet."
    video="/mars.webm"
  />
	<VideoHeroBlock
	  title="ADVANCING SPACE TRANSPORTATION"
	  subtitle="The Nova Heavy launch system is a fully reusable vehicle designed to carry satellites, cargo, and future crews to orbit and deep-space destinations."
	  video="/rocket.webm"
	/>

  <FooterBlock>
    <p>Design inspired by <a href="https://spacex.com" target="_blank" rel="noopener noreferrer">SpaceX</a>. Built for learning purposes only — not affiliated with or endorsed by SpaceX.</p>
  </FooterBlock>
</Layout>

<style>
  .logo {
    font-size: 1.25rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    color: inherit;
  }

  p {
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.5);
  }

  a {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: underline;
    text-underline-offset: 0.2em;

    &:hover {
      color: white;
    }
  }
</style>
